# FAAZO Backend – Git Ignore Rules

# Environment files (NEVER commit)
.env
.env.local
.env.production

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.venv/
ENV/

# Django
*.log
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# Coverage
.coverage
coverage.xml
htmlcov/

# Pytest
.pytest_cache/
.tox/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Distribution
dist/
build/
*.egg-info/
