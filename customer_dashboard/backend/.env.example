# ============================================================
# FAAZO Backend – Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ============================================================
# Django Core
# ============================================================
SECRET_KEY=your-very-long-random-secret-key-here-minimum-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# Database (Leave empty for development – SQLite is used)
# Fill in for production PostgreSQL
# ============================================================
DB_NAME=faazo_db
DB_USER=faazo_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# CORS – Allowed Frontend Origins
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
# Cookie Security
# Set to True only in production (requires HTTPS)
# ============================================================
COOKIE_SECURE=False

# ============================================================
# Email Configuration
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=noreply@faazo.com

# ============================================================
# Frontend URL (used in email verification links)
# ============================================================
FRONTEND_URL=http://localhost:5173

# ============================================================
# Amazon S3 / Cloudflare R2 (Production Only)
# ============================================================
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_STORAGE_BUCKET_NAME=faazo-media
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_CUSTOM_DOMAIN=cdn.faazo.com

# ============================================================
# Razorpay Payment Gateway
# ============================================================
# Get your keys from: https://dashboard.razorpay.com/app/keys
#
# SECURITY RULES:
#   RAZORPAY_KEY_ID      → Public. Safe to send to browser (used by Razorpay JS SDK).
#   RAZORPAY_KEY_SECRET  → Private. NEVER expose to frontend. Used for HMAC verification.
#   RAZORPAY_WEBHOOK_SECRET → Private. Used to verify incoming webhooks from Razorpay.
#
# BEHAVIOR:
#   - Leave all three EMPTY → the app uses the built-in Sandbox Simulator
#     (no real Razorpay network calls; works offline / in CI)
#   - Set TEST keys (rzp_test_...) → app uses real Razorpay Test Checkout overlay
#   - Set LIVE keys (rzp_live_...) → app uses real Razorpay Live Checkout (production)
#
# KEY FORMAT:
#   RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
#   RAZORPAY_KEY_SECRET=<your-key-secret>
#   RAZORPAY_WEBHOOK_SECRET=<your-webhook-secret>
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
